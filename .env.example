# =============================================================================
# Agent Manager — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and fill in your values.
# The application loads these via Spring Boot's ${VAR:default} syntax.
# NEVER commit the actual .env file to version control!
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=knowledgebot
DB_USERNAME=postgres
DB_PASSWORD=password

# ── Docker Compose (for docker-compose.yml) ─────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=knowledgebot

# ── Knowledge Base ──────────────────────────────────────────────────────────
# Path to the folder where you drop PDFs, markdown, and code samples
# The agent will index these and use them during every task.
# KNOWLEDGE_BASE_PATH=C:/Users/YourName/.agentmanager/knowledge

# ── Notification Integrations (all optional) ────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# GENERIC_WEBHOOK_URL=https://your-webhook-endpoint.com/notify
