### Step 9.5 — Key Component: ToolCallCard

This is the visual element that shows when the agent uses a tool:

```jsx
// src/components/chat/ToolCallCard.jsx
/**
 * WHY: Unlike a regular chatbot, our agent DOES THINGS.
 * We need to visually show what tools it's using in real-time.
 *
 * RENDERS LIKE:
 *  ┌─ 📄 readFile ─────────────────────┐
 *  │ Path: src/main/java/App.java       │
 *  │ Status: ✅ Success (243 lines)     │
 *  └────────────────────────────────────┘
 *
 *  ┌─ 📝 writeFile ────────────────────┐
 *  │ Path: src/main/java/User.java      │
 *  │ Status: ✅ Created (45 lines)      │
 *  └────────────────────────────────────┘
 *
 *  ┌─ ⚡ runCommand ────────────────────┐
 *  │ Command: mvn compile               │
 *  │ Status: ❌ FAILED (exit code 1)    │
 *  │ ▼ Show output                      │
 *  └────────────────────────────────────┘
 */
export function ToolCallCard({ tool }) {
  const icons = {
    readFile: '📄', writeFile: '📝', listDirectory: '📁',
    runCommand: '⚡', webSearch: '🌐', searchCodebase: '🔍',
    editFile: '✏️', createDirectory: '📁', deleteFile: '🗑️'
  };

  return (
    <motion.div className="tool-call-card"
      initial={{ opacity: 0, x: -10 }}
      animate={{ opacity: 1, x: 0 }}>
      <div className="tool-header">
        <span className="tool-icon">{icons[tool.name] || '🔧'}</span>
        <span className="tool-name">{tool.name}</span>
        <span className={`tool-status ${tool.success ? 'success' : 'failed'}`}>
          {tool.success ? '✅' : '❌'}
        </span>
      </div>
      <div className="tool-args">
        {Object.entries(tool.arguments).map(([key, val]) => (
          <div key={key} className="tool-arg">
            <span className="arg-key">{key}:</span>
            <span className="arg-value">{String(val).substring(0, 100)}</span>
          </div>
        ))}
      </div>
    </motion.div>
  );
}
