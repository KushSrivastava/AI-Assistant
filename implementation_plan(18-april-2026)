public AgentResponse execute(String userMessage, List<AgentMessage> conversationHistory) {
    // 1. Recall project-specific memories
    String workspacePath = workspaceManager.getActiveWorkspace().toString();
    List<Document> memories = projectMemoryService.recall(workspacePath, userMessage, 5);
    String memoryContext = memories.stream()
        .map(Document::getText)
        .collect(Collectors.joining("\n"));

