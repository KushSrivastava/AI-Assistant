 * Without this it can only use what's in its training data and local knowledge.
 *
 * HOW: We use DuckDuckGo's HTML endpoint (no API key required).
 * We fetch the search results page, parse the result snippets,
 * and return them to the LLM.
 *
 * ALTERNATIVE: For better results, you can self-host SearXNG
 * (a privacy-respecting metasearch engine) via Docker.
 */
@Component
public class WebSearchTool {

    private final HttpClient httpClient = HttpClient.newBuilder()
        .connectTimeout(Duration.ofSeconds(10))
        .build();

    @Tool(description = "Search the internet for information. Use this when you need to look up documentation, find API examples, or learn about a library you're not familiar with. Returns top search results with snippets.")
    public String webSearch(
        @ToolParam(description = "The search query, e.g. 'Spring Boot 4 REST controller example'") String query
    ) {
        try {
            String url = "https://html.duckduckgo.com/html/?q=" + URLEncoder.encode(query, "UTF-8");

            HttpRequest request = HttpRequest.newBuilder()
                .uri(URI.create(url))
                .header("User-Agent", "AgentManager/1.0")
                .GET()
                .build();

            HttpResponse<String> response = httpClient.send(request, HttpResponse.BodyHandlers.ofString());
            String html = response.body();

            // Parse the HTML to extract results
            // DuckDuckGo HTML results have class "result__snippet" for snippets
            // and "result__a" for links
            return parseSearchResults(html, 5); // Return top 5 results

        } catch (Exception e) {
            return "ERROR: Web search failed: " + e.getMessage();
        }
    }

