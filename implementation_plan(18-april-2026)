@Component
public class DirectoryListTool {

    @Tool(description = "List all files and subdirectories at a given path in the workspace. Use this to explore the project structure.")
    public String listDirectory(
        @ToolParam(description = "Relative directory path, e.g. 'src/main/java' or '.' for root") String path
    ) {
        Path fullPath = workspaceManager.resolve(path);
        // Walk the directory tree (max 3 levels deep to avoid flooding)
        // Return a tree-like string representation
        StringBuilder sb = new StringBuilder();
        sb.append("📂 ").append(path).append("/\n");
        try (Stream<Path> walk = Files.walk(fullPath, 3)) {
            walk.forEach(p -> {
                int depth = fullPath.relativize(p).getNameCount();
                String indent = "  ".repeat(depth);
                String icon = Files.isDirectory(p) ? "📁" : "📄";
                sb.append(indent).append(icon).append(" ")
                  .append(p.getFileName()).append("\n");
            });
        }
        return sb.toString();
    }
}
